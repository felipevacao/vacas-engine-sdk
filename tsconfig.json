{
  "compilerOptions": {
    "target": "ES2021", // Define a versão do ECMAScript
    "module": "CommonJS", // Usa módulos CommonJS
    "outDir": "./dist", // Pasta de saída para os arquivos compilados
    "rootDir": "./src", // Pasta de entrada dos arquivos TypeScript
    "strict": true, // Habilita todas as verificações de tipo estritas
    "esModuleInterop": true, // Permite imports de módulos CommonJS
    "skipLibCheck": true, // Ignora a verificação de tipos em arquivos de declaração
    "baseUrl": "./src",
    "paths": {
      "@controllers/*": ["controllers/*"],
      "@adapters/*": ["adapters/*"],
      "@models/*": ["models/*"],
      "@utils/*": ["utils/*"],
      "@entities/*": ["types/entities/*"],
      "@transformers/*": ["transformers/*"],
      "@libs/*": ["libs/*"],
      "@services/*": ["services/*"],
      "@middlewares/*": ["middlewares/*"],
      "@dynamic-modules/*": ["dynamic-modules/*"],
      "@constants/*": ["constants/*"],
      "@repositories/*": ["repositories/*"]
    }
  },
  /* Especifica onde o TypeScript deve procurar por definições de tipo */
  "typeRoots": [
    "./node_modules/@types",
    "./src/types" // Pasta onde está seu express.d.ts
  ],
  /* Garante que as extensões de tipo sejam reconhecidas */
  "types": ["node", "express"],
  /* Inclua explicitamente a pasta de tipos */
  "include": [
    "src/**/*",
    "src/types/**/*" // Inclui seus arquivos de tipo personalizados
  ],
  "exclude": ["node_modules", "dist"] // Exclui pastas desnecessárias
}
