{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "../../../dist/dynamic-modules",
    "baseUrl": ".",
    "paths": {
      "@controllers/*": ["../core/controllers/*"],
      "@app-types/*": ["../core/types/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "../../../dist"]
}
