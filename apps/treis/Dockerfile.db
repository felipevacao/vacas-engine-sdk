# ==============================================================================
# IMAGEM DE BANCO DE DADOS DO MOTOR TREIS (apidb:latest)
# ==============================================================================
FROM postgres:18-alpine

LABEL project="Vacas-Engine"
LABEL component="Treis-DB-Core"

# Copia o script de inicialização do CORE para a pasta de auto-execução do Postgres
# O prefixo '10-' garante que ele rode antes de scripts específicos de cada App
# COPY db/init.sql /docker-entrypoint-initdb.d/10-core-init.sql
# RUN chown -R postgres:postgres /docker-entrypoint-initdb.d/

# Garanta que o diretório existe e tem o dono correto
RUN mkdir -p /docker-entrypoint-initdb.d/

# Use o COPY com permissões explícitas no momento da cópia
# O --chown garante que o Postgres tenha acesso total ao arquivo desde o build
COPY --chown=postgres:postgres db/init.sql /docker-entrypoint-initdb.d/10-core-init.sql
RUN ls -l /docker-entrypoint-initdb.d/

# Garanta que o script seja executável (o postgres exige isso para rodar)
RUN chmod +x /docker-entrypoint-initdb.d/10-core-init.sql

# Saúde do banco
HEALTHCHECK --interval=5s --timeout=5s --retries=5 \
    CMD pg_isready -U ${POSTGRES_USER:-felipe} -d ${POSTGRES_DB:-apitreis}
