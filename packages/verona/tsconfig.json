{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    // "moduleResolution": "node",
    "paths": {
      "@core/*": ["./src/*"],
      "@libs/*": ["./src/libs/*"],
      "@types": ["./src/types"],
      "@metadata": ["./src/metadata"],
      "@interfaces": ["./src/interfaces"],
      "@forms": ["./src/forms"],
      "@api": ["./src/api"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "dist"]
}
